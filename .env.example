# ── Supabase（已由 provisioning 生成，真实值在本地 .env，勿提交） ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon key：公开客户端凭证，行级权限由 RLS 保证>
SUPABASE_SERVICE_ROLE_KEY=<仅服务端使用，已注入 Vercel production env>
SUPABASE_DB_PASSWORD=<数据库密码，supabase db push 时使用>

# ── Supabase Send SMS Hook（已生成并同时注入 Vercel 与 supabase config） ──
SEND_SMS_HOOK_SECRET=v1,whsec_<base64>

# ── 阿里云短信（待企业资质签名/模板报备后填写，然后 vercel env add 三件套） ──
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=<已报备短信签名>
ALIYUN_SMS_TEMPLATE_CODE=<SMS_xxxxxxxx，模板变量为 {"code":"..."}>

# ── 微信开放平台网站应用（需企业主体资质 + ICP 备案回调域名，审核约 7 个工作日） ──
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 合成邮箱域（微信用户在 auth.users 中的占位邮箱后缀，可不改）
WECHAT_EMAIL_DOMAIN=wechat.guanji.invalid
